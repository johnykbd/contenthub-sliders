{
    "compilerOptions": {
        "outDir": "./dist/",
        "target": "ES2015",
        "module": "ES2015",
        "lib": ["ES2015", "DOM"],
        "allowJs": true,
        "jsx": "react-jsx",
        "strict": true,
        "moduleResolution": "node",
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    }
}
